# ──────────────────────────────────────────────────────────────────────────────
# WaffleFinance Relayer — environment variable reference
#
# Copy this file to .env and fill in every value before starting the service.
# Lines beginning with # are comments.  Do NOT commit a populated .env file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────

# Target network: "testnet" or "mainnet"
RELAYER_NETWORK=testnet

# ── Ethereum ──────────────────────────────────────────────────────────────────

# JSON-RPC endpoint for the target Ethereum network (Infura, Alchemy, etc.)
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Private key for the relayer's Ethereum wallet (hex, 0x-prefixed, 64 chars).
# This key signs ETH-side HTLC and escrow transactions.
# REQUIRED — the service will refuse to start if this is absent or a placeholder.
# Generate: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY_HERE

# ── Admin operations ──────────────────────────────────────────────────────────

# Private key used exclusively by POST /api/admin/authorize-relayer to sign
# the on-chain resolver-authorisation transaction.  This key should hold a
# small amount of ETH for gas only.  It is NEVER accepted in a request body.
# REQUIRED to use the authorize-relayer endpoint.
RELAYER_ADMIN_PRIVATE_KEY=0xYOUR_ADMIN_PRIVATE_KEY_HERE

# Bearer token required for all /api/admin/* and /api/debug/* routes.
# Use a long, randomly-generated string (≥ 32 printable ASCII characters).
# If absent or blank the service starts but ALL admin endpoints return 401.
# REQUIRED for production — fail-closed without this value.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RELAYER_ADMIN_API_KEY=your-long-random-secret-here

# ── Stellar ───────────────────────────────────────────────────────────────────

# Stellar Horizon endpoint
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar secret key for the relayer's Stellar account (S…).
# Used to create and claim Stellar-side HTLCs.
# REQUIRED — the service will refuse to start if this is absent or a placeholder.
# Generate: stellar keys generate  (or: node -e "const {Keypair}=require('@stellar/stellar-sdk');console.log(Keypair.random().secret())")
RELAYER_STELLAR_SECRET=SYOUR_STELLAR_SECRET_KEY_HERE

# Optional per-network overrides (take precedence over RELAYER_STELLAR_SECRET).
# Use these when the testnet and mainnet relayer accounts differ.
# RELAYER_STELLAR_SECRET_TESTNET=SYOUR_TESTNET_SECRET
# RELAYER_STELLAR_SECRET_MAINNET=SYOUR_MAINNET_SECRET

# ── Runtime ───────────────────────────────────────────────────────────────────

# Set to "production" to enable production hardening:
#   - /api/test and /api/test-transaction are gated behind RELAYER_ADMIN_API_KEY
#   - Additional startup checks may apply
NODE_ENV=development

# Port the HTTP server listens on (default: 3001)
# PORT=3001

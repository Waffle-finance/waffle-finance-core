# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# Network Configuration
# Can be "mainnet" or "testnet"
VITE_NETWORK_MODE=testnet

# Debug Logging
# Enable structured logging for wallet connections, transactions, and API calls
# Set to 'true' to enable debug logging in development mode
VITE_DEBUG_LOGGING=false

# Enable mock data for development/testing
VITE_ENABLE_MOCK_DATA=false
